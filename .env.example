# =============================================================================
# Banjara — Vercel environment variables
# =============================================================================
# Copy this file to .env.local for local serverless function development
# (`vercel dev`), and set the same keys in Vercel → Settings → Environment
# Variables for production.
#
# These are SERVER-side secrets. They never reach the browser.
# Public client values (Supabase URL + anon key) live in js/config.js and are
# safe to commit.
# =============================================================================

# Required — bypasses RLS to confirm payments and modify reservations server-side
SUPABASE_URL=https://klrjilcpjxzvcbztpnfp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me__service_role_key_from_supabase_settings_api

# Razorpay — only required when PAYMENT_MODE flips to "razorpay" in js/config.js
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Resend — only required once email confirmations are wired in
RESEND_API_KEY=
RESEND_FROM_EMAIL=Banjara <no-reply@your-domain.in>
